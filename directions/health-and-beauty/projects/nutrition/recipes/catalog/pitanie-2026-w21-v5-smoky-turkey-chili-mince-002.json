  "instructions": [
    "Set Instant Pro to Sauté High.",
    "Add olive oil, onion, and sweet peppers. Cook 4-5 minutes.",
    "Add garlic and spices. Stir 30-45 seconds.",
    "Add ground turkey. Break it up with a spatula and cook 6-8 minutes until mostly pale.",
    "Add 100 ml water/broth and scrape the bottom thoroughly to avoid Burn warning.",
    "Add chopped tomatoes, tomato paste, beans, and remaining water/broth.",
    "Pressure Cook High for 5 minutes.",
    "Natural Release for 7 minutes.",
    "If too liquid, use Sauté Medium 5-8 minutes until thick.",
    "Finish with lemon/lime juice and adjust salt."
  ],
  "storage": [
    "Cool before sealing.",
    "Refrigerate Thursday-Friday portions.",
    "Vacuum-freeze Saturday-Sunday portions."
  ],
  "reheating": [
    "Microwave 2-3 minutes, stirring halfway.",
    "Or reheat in pan with 1-2 tbsp water."
